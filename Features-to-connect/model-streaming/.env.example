# ── LLM Provider Keys (add the ones you want to use) ──────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Groq (free tier available at console.groq.com)
GROQ_API_KEY=gsk_...

# Ollama (local — no key needed, just run `ollama serve`)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=none

# LM Studio (local — no key needed)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_API_KEY=none

# Together AI
# TOGETHER_API_KEY=...

# ── App ────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/llm_worker"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
PORT=4000
FRONTEND_URL="http://localhost:3000"
